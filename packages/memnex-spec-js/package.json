{
    "name": "memnex-spec",
    "type": "module",
    "version": "0.2.0",
    "description": "Reference JavaScript/TypeScript implementation of the memnex specification — an open standard for portable meeting outputs (transcripts, summaries, action items, decisions).",
    "license": "MIT",
    "author": "Uladz Kha <UladzKha@users.noreply.github.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/UladzKha/memnex.git",
        "directory": "packages/memnex-spec-js"
    },
    "homepage": "https://github.com/UladzKha/memnex/tree/main/packages/memnex-spec-js#readme",
    "bugs": {
        "url": "https://github.com/UladzKha/memnex/issues"
    },
    "keywords": [
        "memnex",
        "json-schema",
        "meeting",
        "transcript",
        "interoperability",
        "open-standard",
        "open-specification",
        "local-first",
        "provenance"
    ],
    "files": [
        "spec",
        "README.md",
        "LICENSE",
        "CHANGELOG.md",
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./v0.1": {
            "types": "./dist/v0.1/index.d.ts",
            "import": "./dist/v0.1/index.js"
        },
        "./v0.2": {
            "types": "./dist/v0.2/index.d.ts",
            "import": "./dist/v0.2/index.js"
        },
        "./types": {
            "types": "./dist/v0.2/types.d.ts"
        },
        "./schema": {
            "default": "./spec/v0.2/meeting-output.schema.json"
        },
        "./schema/v0.1": {
            "default": "./spec/v0.1/meeting-output.schema.json"
        },
        "./schema/v0.2": {
            "default": "./spec/v0.2/meeting-output.schema.json"
        },
        "./examples/v0.1/minimal": {
            "default": "./spec/v0.1/examples/minimal.json"
        },
        "./examples/v0.1/full": {
            "default": "./spec/v0.1/examples/full.json"
        },
        "./examples/v0.2/minimal": {
            "default": "./spec/v0.2/examples/minimal.json"
        },
        "./examples/v0.2/full": {
            "default": "./spec/v0.2/examples/full.json"
        },
        "./examples/v0.2/full-with-config": {
            "default": "./spec/v0.2/examples/full-with-config.json"
        }
    },
    "scripts": {
        "sync-spec": "node scripts/sync-spec.mjs",
        "build:types": "node scripts/build-types.mjs",
        "build:js": "tsc",
        "build": "npm run sync-spec && npm run build:types && npm run build:js",
        "typecheck": "tsc --noEmit -p tsconfig.scripts.json",
        "prepack": "npm run build",
        "prepublishOnly": "npm run build"
    },
    "engines": {
        "node": ">=20.10.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "json-schema-to-typescript": "^15.0.4",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "ajv": "^8.20.0",
        "ajv-formats": "^3.0.1"
    }
}
